# ╔═╡ c7014b32-e4c4-40ff-82a8-1d64869d740a
"""Table KD-430 Room-Temperature Crack Growth Rate Factors, selected by material category"""
function crack_growth_constants(cat)
C0 = df_cg[df_cg.Material .== cat, :C_0][1] #1.95e-10 # in/cycle (ksi*in^1/2)^-m
m = df_cg[df_cg.Material .== cat, :m][1] #3.26 
G = df_cg[df_cg.Material .== cat, :G][1] #6.4
H = df_cg[df_cg.Material .== cat, :H][1] #0.85
I = df_cg[df_cg.Material .== cat, :I][1] #5.5
return (; C0, m, G, H, I)
end

# ╔═╡ 8a1f0f9e-d4c0-4f24-ab00-d235f4ba7c5d
md"*Values of G, H, and I for cast steel and austenitic stainless are unknown. They are conservatively listed as 0" 


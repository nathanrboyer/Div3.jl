# ╔═╡ 1ae98a49-267c-4235-bfcd-b599f7cba0b1
"Removes the function argument list from the latex equation,
so equations are shorter and better match the source text."
function remove_arguments(s::LaTeXString)
    r = r"\\left\(.*?\\right\)"
    return LaTeXString(replace(s, r=>"", count=1))
end

# ╔═╡ 7f7ec542-5613-44b9-8ca8-b4d28867308b
remove_arguments(
	@latexrun a_final(a_init, a_crit, t) = min(0.25 * t, a_init + 0.25 * (a_crit - a_init))
)

# ╔═╡ e7d88ff5-a857-4f69-baa6-c74a1da14b38
remove_arguments(LaTeXString(replace((@latexrun da_dN(C, fR_K, ΔK, m) = C * fR_K * ΔK ^ m), "\\mathrm{da}_{dN}"=>"\\frac{da}{dN}")))

# ╔═╡ 26c52c7f-2223-4636-9f79-f9241564ddc3
remove_arguments(LaTeXString(replace((@latexrun dc_dN(C, fR_K, ΔK, m) = C * fR_K * ΔK ^ m), "\\mathrm{dc}_{dN}"=>"\\frac{dc}{dN}")))

# ╔═╡ 054580e0-7f18-4748-a90e-ce43db4eb05e
remove_arguments(LaTeXString(replace((@latexrun dl_dN(C, fR_K, ΔK, m) = dc_dN(C, fR_K, ΔK, m) * 2), "\\mathrm{dl}_{dN}"=>"\\frac{dl}{dN}")))

# ╔═╡ 64969045-5857-4355-9851-fa02343c3a13
remove_arguments(@latexrun R_K(K_Imin, K_Imax, K_Ires) = (K_Imin + K_Ires) / (K_Imax + K_Ires))

# ╔═╡ b24cea01-f96b-4bbc-99fd-b04d69250d93
remove_arguments(@latexrun function ΔK_th(cat, G, H, R_K, I)
	if cat == carbonsteel
		return max(1.8, min(G * (1 - H * R_K), I))
	elseif cat == highstrsteel
		return max(2.0, min(G * (1 - H * R_K), I))
	elseif cat == "Aluminum alloys"
		return max(0.64, min(G * (1 - H * R_K), I))
	end
end)

# ╔═╡ fc2c02e4-7310-48db-8e8d-a4fc0145eabd
remove_arguments(@latexrun function fR_K(cat, R_K, m)
    C2 = C2dict[cat]
    C3 = C3dict[cat]
    if cat == carbonsteel
        if 0 ≤ R_K < 1
            return (2.88 / (2.88 - R_K)) ^ m
        elseif R_K < 0
            return (1.0 / (1.0 - R_K)) ^ m
        end
    elseif cat == highstrsteel
        if 0 ≤ R_K < 1
            return 1 + C3 * R_K
        elseif R_K < 0
            return (C2 / (C2 - R_K)) ^ m
        end
    elseif cat == martincitic
        if R_K ≥ 0.67
            return 30.53 * R_K - 17.0
        elseif 0 ≤ R_K < 0.67
            return 1.0 + C3 * R_K
        elseif R_K < 0 
            return (C2 / (C2 - R_K)) ^ m
        end
    elseif cat == austincitic
        if 0.79 < R_K < 1.0
            return -43.35 + 57.97 * R_K
        elseif 0 < R_K ≤ 0.79
            return 1.0 + 1.8 * R_K
        elseif R_K ≤ 0 
            return 1.0
        end
    end
end)

# ╔═╡ 9ffbad78-3a84-4e83-a41d-5b053841be54
remove_arguments(@latexrun C(C0, E0, Eop, m) = C0 * (E0 / Eop) ^ m)


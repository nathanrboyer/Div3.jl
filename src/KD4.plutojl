# ╔═╡ da11cfdd-20c0-416f-bc59-9f4c3f82de2f
begin
	carbonsteel = "Carbon and low alloy steels"
	highstrsteel = "High strength low alloy steels"
	martincitic = "Martensitic precipitation-hardened steels"
	austincitic = "Austenitic stainless steels"
	const C2dict = Dict(
		carbonsteel => nothing ,
		highstrsteel => 1.5,
		martincitic => 1.5,
		austincitic => nothing
	)
	const C3dict = Dict(
		carbonsteel => nothing ,
		highstrsteel => 3.53,
		martincitic => 3.48,
		austincitic => nothing
	   )
	tablecat = [highstrsteel, martincitic]
	df = DataFrame(
		Category = tablecat,
	    C2 = [C2dict[option] for option in tablecat],
	    C3 = [C3dict[option] for option in tablecat],
	)
	pretty_table(HTML, df, show_subheader = false)
end

# ╔═╡ 00071238-7b0f-457b-a118-ff0bb4f026f7
